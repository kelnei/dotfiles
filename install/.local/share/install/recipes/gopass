#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/bin"

echo "Fetching latest gopass release..."
LATEST=$(curl -fsSL https://api.github.com/repos/gopasspw/gopass/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
VERSION="${LATEST#v}"

echo "Installing gopass ${LATEST}..."
curl -fsSL "https://github.com/gopasspw/gopass/releases/download/${LATEST}/gopass-${VERSION}-linux-amd64.tar.gz" |
  tar -xz -C /tmp
mv /tmp/gopass "$INSTALL_DIR/gopass"

echo "gopass $("$INSTALL_DIR/gopass" version) installed to $INSTALL_DIR/gopass"
echo "Run 'gopass init' to set up your password store"
