#!/usr/bin/env bash
set -euo pipefail

# prompt for sudo credentials upfront
sudo -v

echo "Installing latest 1Password desktop app..."
curl -fsSL "https://downloads.1password.com/linux/debian/amd64/stable/1password-latest.deb" -o /tmp/1password.deb
sudo dpkg -i /tmp/1password.deb
rm /tmp/1password.deb

echo "1Password installed"
echo "Sign in at https://start.1password.com and then select 'Set up another device' to add your account"
