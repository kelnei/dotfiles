#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/bin"

echo "Installing latest fnm..."
curl -fsSL https://fnm.vercel.app/install | bash -s -- --install-dir "$INSTALL_DIR" --skip-shell

# initialize fnm in the current shell so fnm command is available
source "$HOME/.bashrc.d/50-fnm.sh"

echo "Installing node LTS..."
fnm install --lts
fnm alias default lts-latest

echo "fnm $("$INSTALL_DIR/fnm" --version) installed to $INSTALL_DIR/fnm"
