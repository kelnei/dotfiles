#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/bin"

echo "Fetching latest shfmt release..."
LATEST=$(curl -fsSL https://api.github.com/repos/mvdan/sh/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
VERSION="${LATEST#v}"

echo "Installing shfmt $VERSION..."
curl -fsSL "https://github.com/mvdan/sh/releases/download/${LATEST}/shfmt_${LATEST}_linux_amd64" -o "$INSTALL_DIR/shfmt"
chmod +x "$INSTALL_DIR/shfmt"

echo "shfmt $($INSTALL_DIR/shfmt --version) installed to $INSTALL_DIR/shfmt"
