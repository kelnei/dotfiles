#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

run() {
    echo ""
    echo "==> $1"
    "$SCRIPT_DIR/$1"
}

# Base tools
run install_starship
run install_go
run install_rust
run install_uv
run install_bun
run install_gh
run install_aws
run install_ssm
run install_ripgrep
run install_bat
run install_docker
run install_1password
run install_op
run install_gopass
run install_proton_pass

# fnm must come before claude and codex (npm dependency)
run install_fnm

# source fnm env and activate default node so npm is available to subsequent scripts
eval "$(fnm env --shell bash)"
fnm use default

run install_claude
run install_codex

run install_opencode
run install_neovim
run install_ghostty
run install_tmux
run install_brave

echo ""
echo "All tools installed successfully."
